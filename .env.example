# ExamPortal — Environment Configuration
# Copy this file to .env and fill in the values

# Server
PORT=5510

# Supabase
SUPABASE_URL=<your_supabase_url>
SUPABASE_ANON_KEY=<your_anon_key_here>
SUPABASE_SERVICE_KEY=<your_service_role_key_here>

# JWT (uses Supabase's JWT secret)
JWT_SECRET=your_supabase_jwt_secret

# Notifications (optional — enable as needed)
# SENDGRID_API_KEY=
# TWILIO_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
